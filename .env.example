# Optional. Set to any truthy value to generate a Gatsby webpack statoscope report during build.
ANALYSE_BUNDLE=

# Sanity CMS. Create a free Sanity project, then copy the project ID here.
SANITY_PROJECT_ID=
SANITY_DATASET=production

# Optional. Required only for private datasets, draft overlays, or authenticated imports.
SANITY_API_TOKEN=

# Sanity Studio also accepts the SANITY_STUDIO_* names. Keep them in sync with the values above.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
