{
  "private": true,
  "name": "sertraline-blog",
  "description": "Personal Persian blog built with Gatsby.",
  "version": "0.1.0",
  "author": "Saro",
  "license": "0BSD",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "gatsby build",
    "develop": "gatsby develop",
    "develop:cypress": "cross-env CYPRESS_SUPPORT=y npm run develop",
    "build:cypress": "cross-env CYPRESS_SUPPORT=y npm run build",
    "start": "gatsby develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "typecheck": "tsc --noEmit",
    "validate:content": "node scripts/validate-content.mjs",
    "check": "npm run validate:content && npm run typecheck && npm run build",
    "sanity:dev": "sanity dev",
    "sanity:build": "sanity build",
    "sanity:deploy": "sanity deploy",
    "sanity:graphql": "sanity graphql deploy",
    "sanity:import:mdx": "node scripts/create-sanity-import.mjs",
    "sanity:import:posts": "sanity exec scripts/import-posts-to-sanity.mjs --with-user-token"
  },
  "dependencies": {
    "@lekoarts/gatsby-theme-minimal-blog": "file:./gatsby-theme-minimal-blog",
    "@portabletext/react": "^4.0.3",
    "@sanity/image-url": "^1.2.0",
    "gatsby": "^5.16.1",
    "gatsby-plugin-feed": "^5.16.0",
    "gatsby-plugin-image": "^3.16.0",
    "gatsby-plugin-manifest": "^5.16.0",
    "gatsby-plugin-sitemap": "^6.16.0",
    "gatsby-plugin-webpack-statoscope": "^1.0.2",
    "gatsby-source-sanity": "^7.9.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rxjs": "^7.8.2",
    "sanity": "^3.99.0",
    "styled-components": "^6.4.1",
    "xstate": "^5.31.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "cross-env": "^7.0.3",
    "typescript": "^4.9.5"
  }
}
